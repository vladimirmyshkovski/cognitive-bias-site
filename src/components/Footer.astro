---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<footer class="bg-slate-100 dark:bg-slate-800 border-t border-slate-200 dark:border-slate-700 mt-16">
  <div class="container mx-auto px-4 py-8">
    <div class="grid md:grid-cols-3 gap-8 text-sm">
      <div>
        <h3 class="font-bold mb-2">Cognitive Bias Encyclopedia</h3>
        <p class="text-slate-600 dark:text-slate-400">
          Открытая русскоязычная энциклопедия когнитивных искажений.
        </p>
      </div>
      <div>
        <h3 class="font-bold mb-2">Ресурсы</h3>
        <ul class="space-y-1 text-slate-600 dark:text-slate-400">
          <li><a href={`${base}llms.txt`} class="hover:text-primary-600">llms.txt</a> — для AI-агентов</li>
          <li><a href={`${base}llms-full.txt`} class="hover:text-primary-600">llms-full.txt</a> — полный текст</li>
          <li><a href={`${base}sitemap-index.xml`} class="hover:text-primary-600">Sitemap</a></li>
        </ul>
      </div>
      <div>
        <h3 class="font-bold mb-2">Источник</h3>
        <ul class="space-y-1 text-slate-600 dark:text-slate-400">
          <li><a href="https://github.com/vladimirmyshkovski/cognitive-bias-encyclopedia" class="hover:text-primary-600" rel="noopener external" target="_blank">GitHub репозиторий ↗</a></li>
          <li><a href="https://github.com/vladimirmyshkovski/cognitive-bias-encyclopedia/blob/main/CONTRIBUTING.md" class="hover:text-primary-600" rel="noopener external" target="_blank">CONTRIBUTING.md ↗</a></li>
          <li>Лицензия: <a href="https://github.com/vladimirmyshkovski/cognitive-bias-encyclopedia/blob/main/LICENSE" class="hover:text-primary-600" rel="noopener external" target="_blank">CC BY-SA 4.0 ↗</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-8 pt-4 border-t border-slate-200 dark:border-slate-700 text-center text-xs text-slate-500">
      © {year} Vladimir Myshkovski. Лицензия <a href="https://creativecommons.org/licenses/by-sa/4.0/" class="hover:text-primary-600" rel="noopener external" target="_blank">CC BY-SA 4.0</a>.
    </div>
  </div>
</footer>
