---
import { loadAllBiases } from '../../../lib/biases';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import Pagination from '../../../components/Pagination.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

export async function getStaticPaths({ paginate }: any) {
  const allBiases = await loadAllBiases();
  allBiases.sort((a, b) => a.title.localeCompare(b.title, 'ru'));
  // Skip page 1 — served by /biases/index.astro
  return paginate(allBiases, { pageSize: 24 }).filter((p: any) => p.props.page.currentPage > 1);
}

// Astro passes `page` prop automatically when using paginate()
const { page } = Astro.props as {
  page: {
    data: typeof import('../../../lib/biases').ParsedBias extends never ? never : any[];
    currentPage: number;
    lastPage: number;
    total: number;
    url: { current: string; prev?: string; next?: string };
  };
};

const biases = page.data;
const currentPage = page.currentPage;
const totalPages = page.lastPage;
const startIndex = (page.start ?? 0) + 1;
const endIndex = page.end ?? biases.length;
const total = page.total;
const displayStart = (currentPage - 1) * 24 + 1;
const displayEnd = Math.min(displayStart + biases.length - 1, total);
---

<BaseLayout
  title={`Каталог когнитивных искажений — страница ${currentPage}`}
  description={`Полный каталог из ${total} когнитивных искажений, страница ${currentPage} из ${totalPages}.`}
>
  <Navbar />
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">Каталог искажений</h1>
    <p class="text-slate-600 dark:text-slate-300 mb-8">
      Показаны {displayStart}–{displayEnd} из {total} записей в 6 категориях
    </p>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {biases.map((b: any) => (
        <li>
          <a
            href={`${base}biases/${b.slug}/`}
            class="block p-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-md hover:border-primary-500 transition-colors"
          >
            <span class="inline-block text-xs px-2 py-0.5 bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300 rounded mb-1 capitalize">
              {b.category}
            </span>
            <h2 class="font-bold text-sm">{b.title}</h2>
          </a>
        </li>
      ))}
    </ul>

    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      baseUrl={`${base}biases/`}
      base={base}
    />
  </main>
  <Footer />
</BaseLayout>