---
import { loadAllBiases } from '../../lib/biases';
import { renderMarkdown } from '../../lib/markdown';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

export async function getStaticPaths() {
  const biases = await loadAllBiases();
  return biases.map((b) => ({
    params: { slug: b.slug },
    props: { bias: b },
  }));
}

const { bias } = Astro.props;
const html = await renderMarkdown(bias.body, base);
const descriptionHtml = bias.description ? await renderMarkdown(bias.description, base) : '';
---

<BaseLayout
  title={bias.title}
  description={bias.description}
  category={bias.category}
  slug={bias.slug}
>
  <Navbar />
  <main class="container mx-auto px-4 py-8 max-w-3xl">
    <article>
      <header class="mb-8 pb-6 border-b border-slate-200 dark:border-slate-700">
        <div class="flex items-center gap-2 mb-3 flex-wrap">
          <a href={`${base}categories/${bias.category}/`} class="inline-block text-xs px-2 py-1 bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300 rounded capitalize">
            {bias.category}
          </a>
          {bias.aliases && bias.aliases.length > 0 && (
            <span class="text-xs text-slate-500">
              aka {bias.aliases.slice(0, 3).join(', ')}
            </span>
          )}
        </div>
        <h1 class="text-3xl md:text-4xl font-bold">{bias.title}</h1>
        {descriptionHtml && (
          <div class="mt-3 text-lg text-slate-600 dark:text-slate-300 italic" set:html={descriptionHtml} />
        )}
      </header>

      <div class="prose prose-slate dark:prose-invert max-w-none" set:html={html} />

      <nav class="mt-12 pt-6 border-t border-slate-200 dark:border-slate-700 flex justify-between text-sm">
        <a href={`${base}biases/`} class="text-primary-600 hover:underline">← Каталог</a>
        <a href={`${base}categories/${bias.category}/`} class="text-primary-600 hover:underline capitalize">
          {bias.category} →
        </a>
      </nav>
    </article>
  </main>
  <Footer />
</BaseLayout>
