---
import { loadAllBiases } from '../../lib/biases';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import Pagination from '../../components/Pagination.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const allBiases = await loadAllBiases();

// Sort: alphabetical by title (Russian-aware)
allBiases.sort((a, b) => a.title.localeCompare(b.title, 'ru'));

const PAGE_SIZE = 24;
const totalPages = Math.max(1, Math.ceil(allBiases.length / PAGE_SIZE));
const currentPage = 1;
const biases = allBiases.slice(0, PAGE_SIZE);
const startIndex = (currentPage - 1) * PAGE_SIZE + 1;
const endIndex = Math.min(startIndex + biases.length - 1, allBiases.length);
---

<BaseLayout
  title="Каталог когнитивных искажений"
  description={`Полный каталог из ${allBiases.length} когнитивных искажений, структурированных по функциям.`}
>
  <Navbar />
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">Каталог искажений</h1>
    <p class="text-slate-600 dark:text-slate-300 mb-8">
      {totalPages > 1
        ? `Показаны ${startIndex}–${endIndex} из ${allBiases.length} записей в 6 категориях`
        : `${allBiases.length} записей в 6 категориях`}
    </p>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-3">
      {biases.map((b) => (
        <li>
          <a
            href={`${base}biases/${b.slug}/`}
            class="block p-3 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-md hover:border-primary-500 transition-colors"
          >
            <span class="inline-block text-xs px-2 py-0.5 bg-primary-100 dark:bg-primary-900 text-primary-700 dark:text-primary-300 rounded mb-1 capitalize">
              {b.category}
            </span>
            <h2 class="font-bold text-sm">{b.title}</h2>
          </a>
        </li>
      ))}
    </ul>

    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      baseUrl={`${base}biases/`}
      base={base}
    />
  </main>
  <Footer />
</BaseLayout>