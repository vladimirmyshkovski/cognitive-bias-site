---
import { loadAllBiases } from '../../../lib/biases';
import { renderMarkdown } from '../../../lib/markdown';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Navbar from '../../../components/Navbar.astro';
import Footer from '../../../components/Footer.astro';
import Pagination from '../../../components/Pagination.astro';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
const PAGE_SIZE = 24;

export async function getStaticPaths() {
  const biases = await loadAllBiases();
  const byCategory: Record<string, typeof biases> = {};
  for (const b of biases) {
    const cat = b.category || 'other';
    if (!byCategory[cat]) byCategory[cat] = [];
    byCategory[cat].push(b);
  }
  return Object.entries(byCategory).map(([category, items]) => ({
    params: { category },
    props: { category, items },
  }));
}

const { category, items } = Astro.props as {
  category: string;
  items: import('../../../lib/biases').ParsedBias[];
};
items.sort((a, b) => a.title.localeCompare(b.title, 'ru'));

const totalPages = Math.max(1, Math.ceil(items.length / PAGE_SIZE));
const currentPage = 1;
const pageItems = items.slice(0, PAGE_SIZE);
const displayStart = 1;
const displayEnd = pageItems.length;

const itemsWithHtml = await Promise.all(
  pageItems.map(async (b) => ({
    ...b,
    descriptionHtml: await renderMarkdown(b.description, base),
  }))
);
---

<BaseLayout
  title={`${category} — когнитивные искажения`}
  description={`Когнитивные искажения в категории «${category}»: ${items.length} записей.`}
  category={category}
>
  <Navbar />
  <main class="container mx-auto px-4 py-8">
    <nav class="text-sm mb-4">
      <a href={`${base}categories/`} class="text-primary-600 hover:underline">← Все категории</a>
    </nav>
    <h1 class="text-3xl font-bold mb-2 capitalize">{category}</h1>
    <p class="text-slate-600 dark:text-slate-300 mb-6">
      {totalPages > 1
        ? `Показаны ${displayStart}–${displayEnd} из ${items.length} записей`
        : `${items.length} записей`}
    </p>

    <ul class="space-y-3">
      {itemsWithHtml.map((b) => (
        <li>
          <a
            href={`${base}biases/${b.slug}/`}
            class="block p-4 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-md hover:border-primary-500"
          >
            <h2 class="font-bold mb-1">{b.title}</h2>
            <p class="text-sm text-slate-600 dark:text-slate-400 line-clamp-2" set:html={b.descriptionHtml} />
          </a>
        </li>
      ))}
    </ul>

    <Pagination
      currentPage={currentPage}
      totalPages={totalPages}
      baseUrl={`${base}categories/${category}/`}
      base={base}
    />
  </main>
  <Footer />
</BaseLayout>