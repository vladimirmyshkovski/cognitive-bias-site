---
import { loadAllBiases } from '../../lib/biases';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

const biases = await loadAllBiases();
const byCategory: Record<string, typeof biases> = {};
for (const b of biases) {
  const cat = b.category || 'other';
  if (!byCategory[cat]) byCategory[cat] = [];
  byCategory[cat].push(b);
}
---

<BaseLayout
  title="Категории когнитивных искажений"
  description={`Когнитивные искажения по ${Object.keys(byCategory).length} категориям.`}
>
  <Navbar />
  <main class="container mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold mb-2">Категории</h1>
    <p class="text-slate-600 dark:text-slate-300 mb-8">
      {Object.keys(byCategory).length} категорий
    </p>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {Object.entries(byCategory).map(([cat, items]) => (
        <a
          href={`/categories/${cat}/`}
          class="block p-6 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg hover:border-primary-500 transition-colors"
        >
          <h3 class="text-lg font-bold capitalize mb-2">{cat}</h3>
          <p class="text-sm text-slate-600 dark:text-slate-400">
            {items.length} {items.length === 1 ? 'запись' : items.length < 5 ? 'записи' : 'записей'}
          </p>
        </a>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>
